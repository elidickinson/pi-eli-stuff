{
  "arch": "aarch64",
  "distro": "alpine",
  "env": {
    "USE_BUILTIN_RIPGREP": "0",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_TELEMETRY": "1",
    "BR_AUTOSTART": "1"
  },
  "alpine": {
    "version": "3.23.0",
    "kernelPackage": "linux-virt",
    "kernelImage": "vmlinuz-virt",
    "rootfsPackages": [
      "linux-virt",
      "rng-tools",
      "bash",
      "ca-certificates",
      "curl",
      "nodejs",
      "npm",
      "uv",
      "python3",
      "openssh",
      "libgcc",
      "libstdc++",
      "ripgrep",
      "git"
    ],
    "initramfsPackages": []
  },
  "rootfs": {
    "label": "gondolin-root"
  },
  "postBuild": {
    "commands": [
      "rm -rf /usr/lib/node_modules/npm && mkdir -p /usr/lib/node_modules/npm && curl -fsSL https://registry.npmjs.org/npm/-/npm-11.2.0.tgz | tar -xz -C /usr/lib/node_modules/npm --strip-components=1",
      "npm install -g @anthropic-ai/claude-code",
      "npm install -g https://github.com/elidickinson/browser-cli/archive/refs/heads/main.tar.gz",
      "mkdir -p /root/.claude && echo '{\"skipDangerousModePermissionPrompt\":true}' > /root/.claude/settings.json",
      "printf '[safe]\\n\\tdirectory = *\\n' > /etc/gitconfig"
    ]
  }
}
