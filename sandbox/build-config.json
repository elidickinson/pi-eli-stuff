{
  "arch": "aarch64",
  "distro": "alpine",
  "env": {
    "USE_BUILTIN_RIPGREP": "0",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_TELEMETRY": "1",
    "BR_AUTOSTART": "1",
    "UV_PROJECT_ENVIRONMENT": ".venv-sandbox"
  },
  "alpine": {
    "version": "3.23.0",
    "kernelPackage": "linux-virt",
    "kernelImage": "vmlinuz-virt"
  },
  "oci": {
    "image": "gondolin-sandbox-base",
    "pullPolicy": "never"
  },
  "rootfs": {
    "label": "gondolin-root"
  }
}
