{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node"],
		"paths": {
			"@mariozechner/pi-coding-agent": ["./vendor/pi-mono/packages/coding-agent/dist/index.d.ts"],
			"@mariozechner/pi-tui": ["./vendor/pi-mono/packages/tui/dist/index.d.ts"],
			"@mariozechner/pi-ai": ["./vendor/pi-mono/node_modules/@mariozechner/pi-ai/dist/index.d.ts"],
			"@sinclair/typebox": ["./vendor/pi-mono/node_modules/@sinclair/typebox/build/esm/index.d.mts"]
		}
	},
	"include": ["extensions/**/*.ts"],
	"exclude": ["node_modules", "vendor"]
}
